    "\n",
    "for method in methods:\n",
    "    print(f\"\\n--- Метод: {method} ---\")\n",
    "    \n",
    "    # Замер времени начала\n",
    "    start_time = time.time()\n",
    "    \n",
    "    # Решение задачи линейного программирования\n",
    "    result = linprog(\n",
    "        c=c,\n",
    "        A_ub=A_ub,\n",
    "        b_ub=b_ub,\n",
    "        A_eq=A_eq,\n",
    "        b_eq=b_eq,\n",
    "        bounds=bounds,\n",
    "        method=method\n",
    "    )\n",
    "    \n",
    "    # Замер времени окончания\n",
    "    end_time = time.time()\n",

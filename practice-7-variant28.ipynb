    "    \n",
    "    # Сохранение результатов\n",
    "    results[method] = {\n",
    "        'success': result.success,\n",
    "        'fun': result.fun,\n",
    "        'x': result.x,\n",
    "        'time': elapsed_time,\n",
    "        'message': result.message\n",

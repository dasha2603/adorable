    "c = [15, 17, 19, 21, 18, 16, 18, 20]\n",
    "\n",
    "# Матрица ограничений-неравенств (мощности площадок)\n",
    "A_ub = [\n",
    "    [1, 1, 1, 1, 0, 0, 0, 0],  # P1: сумма поставок ≤ 30\n",
    "    [0, 0, 0, 0, 1, 1, 1, 1]   # P2: сумма поставок ≤ 27\n",
    "]\n",
    "b_ub = [30, 27]\n",
    "\n",
    "# Матрица ограничений-равенств (спрос комбинатов)\n",
    "A_eq = [\n",
    "    [1, 0, 0, 0, 1, 0, 0, 0],  # FC1: x11 + x21 = 15\n",
    "    [0, 1, 0, 0, 0, 1, 0, 0],  # FC2: x12 + x22 = 12\n",
    "    [0, 0, 1, 0, 0, 0, 1, 0],  # FC3: x13 + x23 = 20\n",
    "    [0, 0, 0, 1, 0, 0, 0, 1]   # FC4: x14 + x24 = 10\n",
    "]\n",
    "b_eq = [15, 12, 20, 10]\n",
    "\n",
    "# Границы переменных (неотрицательность)\n",
    "bounds = [(0, None)] * 8\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"МАТРИЦЫ И ВЕКТОРЫ КОЭФФИЦИЕНТОВ (ВАРИАНТ 28)\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nВектор целевой функции c = {c}\")\n",
    "print(f\"\\nМатрица неравенств A_ub (мощности):\")\n",
    "for row in A_ub:\n",
    "    print(f\"   {row}\")\n",
    "print(f\"\\nВектор b_ub = {b_ub}\")\n",
    "print(f\"\\nМатрица равенств A_eq (спрос):\")\n",
    "for row in A_eq:\n",
    "    print(f\"   {row}\")\n",
    "print(f\"\\nВектор b_eq = {b_eq}\")\n",
    "print(f\"\\nГраницы переменных: x_i ≥ 0 для всех i\")"
   ]

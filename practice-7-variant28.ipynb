    "# Решение задачи разными методами с замером времени\n",
    "\n",
    "methods = ['highs', 'simplex', 'interior-point']\n",
    "results = {}\n",
    "\n",
    "print(\"\\n\" + \"=\" * 70)\n",
    "print(\"РЕШЕНИЕ ЗАДАЧИ РАЗНЫМИ МЕТОДАМИ\")\n",
